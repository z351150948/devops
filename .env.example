# SxDevOps / Autotoll Devops - environment template
# Copy this file to .env and fill in real values before `docker compose up -d`.
# .env is git-ignored; never commit it.

# ---- Core secrets (REQUIRED) ----
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(24))"
SECRET_KEY=change-me-to-a-random-24+-char-string
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PASSWORD=change-me-app-password

# ---- Database / Redis ----
MYSQL_DATABASE=sxdevops
MYSQL_USER=sxdevops
# MYSQL_HOST, MYSQL_PORT, REDIS_URL are set automatically inside the compose network.

# ---- App runtime ----
DEBUG=0
CORS_ALLOW_ALL_ORIGINS=1
SXDEVOPS_PORT=8000

# ---- Bootstrap behaviour ----
# 0022 migration removes the built-in demo provider "智能助手体验版".
# SXDEVOPS_SEED_DATA and SXDEVOPS_SEED_TEMPLATES only seed reference data
# (sample CMDB hosts, marketplace templates). Keep at 0 for clean installs.
SXDEVOPS_WAIT_FOR_DB=1
SXDEVOPS_MIGRATE=1
SXDEVOPS_SEED_DATA=0
SXDEVOPS_SEED_TEMPLATES=0
SXDEVOPS_SEED_DEMO_PROVIDER=0

# ---- Observability / Tracing (Autotoll Devops default: Tempo) ----
TEMPO_ENABLED=1
SKYWALKING_ENABLED=0
TEMPO_QUERY_URL=http://tempo:3200
TEMPO_UI_URL=http://tempo:3200
TEMPO_DEMO_MODE=0
TRACING_DEFAULT_PROVIDER=tempo
